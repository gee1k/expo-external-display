{
  "name": "expo-external-display",
  "version": "0.1.1",
  "description": "Expo Module for rendering React Native content on an external display",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "ios",
    "android/src",
    "android/build.gradle",
    "expo-module.config.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/",
    "test": "jest --watchman=false",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js",
    "example": "npm --prefix example run start",
    "example:ios": "npm --prefix example run ios",
    "example:android": "npm --prefix example run android"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-external-display",
    "ExpoExternalDisplay"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gee1k/expo-external-display.git"
  },
  "bugs": {
    "url": "https://github.com/gee1k/expo-external-display/issues"
  },
  "author": "Svend <svend.jin@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/gee1k/expo-external-display#readme",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.1.1",
    "babel-preset-expo": "~55.0.8",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "^56.0.11",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.0.0",
    "react-native": "0.82.1",
    "typescript": "^5.9.2"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "transform": {
      "^.+\\.[tj]sx?$": "babel-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
